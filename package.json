{
  "name": "officegen-cli",
  "version": "1.2.1",
  "private": false,
  "description": "Officegen CLI workspace",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/formats packages/optional packages/cli",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "typecheck": "tsc -b packages/core packages/formats packages/optional packages/cli --pretty false",
    "officegen": "node packages/cli/dist/main.js",
    "binary:smoke": "node scripts/binary-smoke.mjs"
  },
  "bin": {
    "officegen": "packages/cli/dist/main.js"
  },
  "dependencies": {
    "@officegen/core": "file:packages/core",
    "@officegen/formats": "file:packages/formats",
    "@officegen/optional": "file:packages/optional",
    "ajv": "^8.17.1",
    "commander": "^14.0.1",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.2.5",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
