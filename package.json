{
  "name": "officegen-release-tools",
  "version": "5.2.0",
  "private": true,
  "description": "Development and release tooling for the Officegen Rust-native CLI",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node scripts/run-cargo.mjs build --release --locked",
    "clean": "node scripts/clean.mjs",
    "test": "node scripts/run-cargo.mjs test --locked",
    "typecheck": "node scripts/run-cargo.mjs check --locked",
    "officegen:native": "node scripts/run-cargo.mjs run --",
    "native:smoke": "node scripts/native-release-smoke.mjs",
    "native:assets:check": "node scripts/check-native-release-assets.mjs",
    "installer:smoke": "node scripts/installer-smoke.mjs",
    "v5:acceptance": "node scripts/v5-acceptance.mjs",
    "release:gate": "npm run version:check && npm run installer:smoke && node scripts/run-cargo.mjs fmt --check && npm test && npm run build && npm run v5:acceptance -- --expected-version current && npm run native:smoke -- --expected-version current && npm run typecheck && npm run remediation:check",
    "benchmark:fetch": "node scripts/benchmark-fetch.mjs",
    "benchmark:review": "node scripts/benchmark-review.mjs",
    "remediation:check": "node scripts/check-remediation-matrix.mjs",
    "version:bump": "node scripts/version-bump.mjs",
    "version:check": "node scripts/version-bump.mjs --check"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
