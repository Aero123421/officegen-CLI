{
  "name": "officegen",
  "version": "2.1.0",
  "private": false,
  "description": "Officegen CLI",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/formats packages/optional packages/cli && node scripts/patch-dist-imports.mjs",
    "clean": "node scripts/clean.mjs",
    "prepare": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -b packages/core packages/formats packages/optional packages/cli --pretty false",
    "officegen": "node packages/cli/dist/main.js",
    "binary:smoke": "node scripts/binary-smoke.mjs",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "version:bump": "node scripts/version-bump.mjs",
    "version:check": "node scripts/version-bump.mjs --check"
  },
  "bin": {
    "officegen": "packages/cli/dist/main.js"
  },
  "dependencies": {
    "@embedpdf/fonts-jp": "^1.0.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "ajv": "^8.17.1",
    "commander": "^14.0.1",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.2.5",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
