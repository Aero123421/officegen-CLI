{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "officegen.error.catalog@1.2",
  "title": "Officegen error catalog",
  "type": "object",
  "required": [
    "schema",
    "version",
    "errors"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "officegen.error.catalog@1.2" },
    "version": { "type": "string" },
    "errors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "category", "severity"],
        "additionalProperties": true,
        "properties": {
          "code": { "type": "string" },
          "category": { "type": "string" },
          "severity": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
