{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "officegen.workflow@2.0",
  "type": "object",
  "required": ["schema", "steps"],
  "properties": {
    "schema": { "const": "officegen.workflow@2.0" },
    "version": { "type": "string" },
    "outputRoot": { "type": "string" },
    "denyOutsideOutputRoot": { "type": "boolean" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "command"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "input": { "type": "string" },
          "before": { "type": "string" },
          "after": { "type": "string" },
          "ops": { "type": "string" },
          "out": { "type": "string" },
          "target": { "type": "string" },
          "format": { "type": "string" },
          "sheet": { "type": "string" },
          "range": { "type": "string" },
          "slides": { "type": "string" },
          "pages": { "type": "string" },
          "data": { "type": "string" },
          "schema": { "type": "string" },
          "manifest": { "type": "string" },
          "trace": { "type": "string" },
          "summary": { "type": "string" },
          "args": {
            "type": "array",
            "items": { "type": "string" }
          },
          "dryRun": { "type": "boolean" },
          "resolveSelectors": { "type": "boolean" },
          "visual": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
