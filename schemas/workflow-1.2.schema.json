{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "officegen.workflow@1.2",
  "title": "Officegen workflow",
  "type": "object",
  "required": [
    "schema",
    "version",
    "steps"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "officegen.workflow@1.2" },
    "version": { "type": "string" },
    "name": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "command": { "type": "string" }
        }
      }
    }
  }
}
