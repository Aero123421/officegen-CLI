{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "officegen.edit.ops@1.2",
  "title": "Officegen edit operations",
  "type": "object",
  "required": [
    "schema",
    "operations"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "officegen.edit.ops@1.2" },
    "target": { "type": "string" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["op"],
        "additionalProperties": true,
        "properties": {
          "op": { "type": "string" },
          "selector": {
            "type": "object",
            "additionalProperties": true
          },
          "text": { "type": "string" }
        }
      }
    }
  }
}
